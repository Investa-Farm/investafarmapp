
{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/investa-farm/package.json",
      "use": "@vercel/static-build",
      "config": { 
        "distDir": "dist/public",
        "buildCommand": "pnpm --filter @workspace/investa-farm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/index.js"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "dest": "artifacts/investa-farm/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/investa-farm/index.html"
    }
  ]
}
