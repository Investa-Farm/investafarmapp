# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/investa_farm
SESSION_SECRET=your-long-random-secret-here

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Create an App Password at https://myaccount.google.com/apppasswords
GOOGLE_SMTP_USER=your-email@gmail.com
GOOGLE_SMTP_PASS=your-gmail-app-password

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@investafarm.com
ADMIN_PASSWORD=your-secure-admin-password

# ── Payments (Paystack) ──────────────────────────────────────────────────────
# Get keys at https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_your_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_key_here

# ── AI (Groq) ────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Frontend (Vite build-time vars) ──────────────────────────────────────────
# Only needed when building the frontend
BASE_PATH=/

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate a new pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
